{
  "ReverseProxy": {
    "Routes": {
      "StaticContentRoute": {
        "ClusterId": "StaticContentCluster",
        "Match": {
          "Path": "/Content/{**any}"
        },
        "Order": 1
      },
      "StaticScriptsRoute": {
        "ClusterId": "StaticScriptsCluster",
        "Match": {
          "Path": "/Scripts/{**any}"
        },
        "Order": 1
      },
      "Old_chaps": {
        "ClusterId": "framework_481_Cluster",
        "Match": {
          "Path": "{**any}"
        },
        "Order": 2,
        "Transforms": [
          {
            "RequestHeader": "Authorization",
            "Set": "{httpContext.Request.Headers.Authorization}"
          },
          {
            "RequestHeadersCopy": true
          },
          {
            "RequestHeader": "X-User-Name",
            "Set": "{User.Identity.Name}"
          },
          {
            "RequestHeader": "X-User-RoleStrength",
            "Set": "{User.Identity.RoleStrength}"
          },
          {
            "RequestHeader": "X-Forwarded-For", 
            "Append": "{RemoteIpAddress}"
          },
          {
            "RequestHeader": "X-Forwarded-Host", 
            "Append": "{Host}"
          },
          {
            "RequestHeader": "X-Forwarded-Proto", 
            "Set": "http"
          }
        ]
      }
    },
    "Clusters": {
      "framework_481_Cluster": {
        "Destinations": {
          "framework481_app": {
            "Address": "http://localhost:80"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp.ReverseProxy": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}